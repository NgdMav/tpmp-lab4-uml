        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nclass User {\n  - id: Int\n  - name: String\n  - email: String\n  - password: String\n  - phone: String\n\n  + register()\n  + login()\n  + logout()\n  + updateProfile()\n}\n\nclass Category {\n  - id: Int\n  - title: String\n  - icon: String\n\n  + getProducts()\n}\n\nclass Product {\n  - id: Int\n  - title: String\n  - description: String\n  - price: Double\n  - stock: Int\n  - imageUrl: String\n\n  + addToCart()\n  + getDetails()\n}\n\nclass Cart {\n  - id: Int\n  - totalPrice: Double\n\n  + addItem()\n  + removeItem()\n  + clearCart()\n  + calculateTotal()\n}\n\nclass CartItem {\n  - id: Int\n  - quantity: Int\n  - subtotal: Double\n\n  + updateQuantity()\n}\n\nclass Order {\n  - id: Int\n  - status: String\n  - totalPrice: Double\n  - createdAt: Date\n\n  + createOrder()\n  + cancelOrder()\n  + splitOrder()\n}\n\nclass OrderItem {\n  - id: Int\n  - quantity: Int\n  - subtotal: Double\n}\n\nclass Payment {\n  - id: Int\n  - paymentMethod: String\n  - amount: Double\n  - paymentStatus: String\n\n  + processPayment()\n  + refund()\n}\n\nclass DeliveryAddress {\n  - id: Int\n  - city: String\n  - street: String\n  - house: String\n  - postalCode: String\n}\n\nclass PickupPoint {\n  - id: Int\n  - title: String\n  - address: String\n  - latitude: Double\n  - longitude: Double\n\n  + selectPoint()\n}\n\nUser \&quot;1\&quot; -- \&quot;1\&quot; Cart\nUser \&quot;1\&quot; -- \&quot;*\&quot; Order\nUser \&quot;1\&quot; -- \&quot;*\&quot; DeliveryAddress\n\nCategory \&quot;1\&quot; -- \&quot;*\&quot; Product\n\nCart \&quot;1\&quot; -- \&quot;*\&quot; CartItem\nCartItem \&quot;*\&quot; -- \&quot;1\&quot; Product\n\nOrder \&quot;1\&quot; -- \&quot;*\&quot; OrderItem\nOrderItem \&quot;*\&quot; -- \&quot;1\&quot; Product\n\nOrder \&quot;1\&quot; -- \&quot;1\&quot; Payment\nOrder \&quot;1\&quot; -- \&quot;0..1\&quot; PickupPoint\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#x